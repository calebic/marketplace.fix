<Window x:Class="WpfApp1.BulkEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        Title="Bulk Edit Fields"
        Height="620"
        Width="760"
        MinHeight="560"
        MinWidth="700"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCardBorderStyle}" Padding="16">
            <StackPanel>
                <TextBlock Text="Bulk Edit Fields" FontSize="22" FontWeight="SemiBold"/>
                <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"
                           Text="Apply shared field changes to many configs at once. Choose a target scope, choose which fields to overwrite, then apply them in one save pass."/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" Margin="0,14,0,14" Style="{StaticResource PanelCardBorderStyle}" Padding="16">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Grid Margin="0,0,0,14">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Scope" VerticalAlignment="Center"/>
                        <ComboBox x:Name="ScopeComboBox" Grid.Column="1" Margin="10,0,0,0" SelectionChanged="ScopeComboBox_SelectionChanged" Style="{StaticResource PresetComboBoxStyle}">
                            <ComboBoxItem Content="Selected mod" IsSelected="True"/>
                            <ComboBoxItem Content="Current filtered results"/>
                            <ComboBoxItem Content="Flagged configs"/>
                        </ComboBox>
                    </Grid>

                    <TextBlock x:Name="ScopeSummaryTextBlock" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap" Margin="0,0,0,18"/>

                    <UniformGrid Columns="2" Margin="0,0,0,12">
                        <CheckBox x:Name="ApplyInsuranceClassCheckBox" Content="Insurance Class" Margin="0,0,16,8"/>
                        <ComboBox x:Name="InsuranceClassComboBox" Margin="0,0,0,8" Style="{StaticResource PresetComboBoxStyle}">
                            <ComboBoxItem Content="dailyDriver" IsSelected="True"/>
                            <ComboBoxItem Content="commercial"/>
                            <ComboBoxItem Content="prestige"/>
                        </ComboBox>

                        <CheckBox x:Name="ApplyPopulationCheckBox" Content="Population" Margin="0,0,16,8"/>
                        <TextBox x:Name="PopulationTextBox" Margin="0,0,0,8" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource InputForegroundBrush}" BorderBrush="{DynamicResource BorderBrush}" VerticalContentAlignment="Center" />

                        <CheckBox x:Name="ApplyValueCheckBox" Content="Value" Margin="0,0,16,8"/>
                        <TextBox x:Name="ValueTextBox" Margin="0,0,0,8" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource InputForegroundBrush}" BorderBrush="{DynamicResource BorderBrush}" VerticalContentAlignment="Center" />

                        <CheckBox x:Name="ApplyBodyStyleCheckBox" Content="Body Style" Margin="0,0,16,8"/>
                        <TextBox x:Name="BodyStyleTextBox" Margin="0,0,0,8" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource InputForegroundBrush}" BorderBrush="{DynamicResource BorderBrush}" VerticalContentAlignment="Center" />

                        <CheckBox x:Name="ApplyTypeCheckBox" Content="Type" Margin="0,0,16,8"/>
                        <TextBox x:Name="TypeTextBox" Margin="0,0,0,8" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource InputForegroundBrush}" BorderBrush="{DynamicResource BorderBrush}" VerticalContentAlignment="Center" />

                        <CheckBox x:Name="ApplyConfigTypeCheckBox" Content="Config Type" Margin="0,0,16,8"/>
                        <TextBox x:Name="ConfigTypeTextBox" Margin="0,0,0,8" Background="{DynamicResource InputBackgroundBrush}" Foreground="{DynamicResource InputForegroundBrush}" BorderBrush="{DynamicResource BorderBrush}" VerticalContentAlignment="Center" />
                    </UniformGrid>

                    <Border Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="What this does" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"
                                       Text="Only checked fields will be overwritten. Unchecked fields are left alone. This operation writes changes back to the mod files in batch."/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource PanelCardBorderStyle}" Padding="14">
            <DockPanel>
                <TextBlock x:Name="FooterSummaryTextBlock" DockPanel.Dock="Left" VerticalAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}"/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Cancel" Width="120" Height="38" Margin="0,0,10,0" Click="Cancel_Click"/>
                    <Button x:Name="ApplyButton" Content="Apply Bulk Edit" Width="160" Height="38" Click="Apply_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
