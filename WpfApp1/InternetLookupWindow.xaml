<Window x:Class="WpfApp1.InternetLookupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WpfApp1"
        Title="Internet Lookup"
        Height="660"
        Width="860"
        MinHeight="600"
        MinWidth="760"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCardBorderStyle}" Padding="18,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="34"
                        Height="34"
                        CornerRadius="10"
                        Background="{DynamicResource StatusBadgeBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        VerticalAlignment="Top">
                    <TextBlock Text="◎"
                               Foreground="{DynamicResource AccentBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" Margin="14,0,0,0">
                    <TextBlock Text="Internet Lookup"
                               FontSize="24"
                               FontWeight="SemiBold"/>
                    <TextBlock Text="Use vehicle metadata as the starting point, then verify and fill pricing-related details from online lookup."
                               Margin="0,6,0,0"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="0.95*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCardBorderStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Vehicle search"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                    <TextBlock Grid.Row="1"
                               Text="Adjust the detected vehicle details, then run an online lookup."
                               Margin="0,6,0,18"
                               Foreground="{DynamicResource MutedForegroundBrush}"
                               TextWrapping="Wrap"/>

                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="0,0,4,0">
                            <TextBlock Text="Make" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox x:Name="MakeTextBox" Margin="0,6,0,14"/>

                            <TextBlock Text="Model" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox x:Name="ModelTextBox" Margin="0,6,0,14"/>

                            <Grid Margin="0,0,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="12"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="Year start" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <TextBox x:Name="YearMinTextBox" Margin="0,6,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Year end" Style="{StaticResource FormFieldLabelStyle}"/>
                                    <TextBox x:Name="YearMaxTextBox" Margin="0,6,0,0"/>
                                </StackPanel>
                            </Grid>

                            <TextBlock Text="Body style" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox x:Name="BodyStyleTextBox" Margin="0,6,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,18,0,0">
                        <Button x:Name="SearchOnlineButton"
                                Content="Lookup Online"
                                Width="148"
                                Height="36"
                                HorizontalAlignment="Left"
                                Click="Search_Click"/>
                        <TextBlock Margin="12,0,0,0"
                                   VerticalAlignment="Center"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   Text="Runs internet-assisted pricing and detail lookup."/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource PanelCardBorderStyle}" Padding="18">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel>
                        <TextBlock Text="Lookup results"
                                   FontSize="18"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text="Select a lookup result, review the source link, then apply it back to the selected config."
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   TextWrapping="Wrap"/>
                        <WrapPanel Margin="0,10,0,0">
                            <Border x:Name="LookupStatusBadge"
                                    Background="{DynamicResource StatusBadgeBackgroundBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Padding="8,3"
                                    Margin="0,0,8,8">
                                <TextBlock x:Name="LookupStatusBadgeText"
                                           Text="Idle"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource AppForegroundBrush}"/>
                            </Border>
                            <TextBlock x:Name="LookupDiagnosticsTextBlock"
                                       Width="260"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       TextWrapping="Wrap"
                                       Text="Run a lookup to see why results ranked well, which fallbacks were used, or why nothing strong was found."/>
                        </WrapPanel>
                    </StackPanel>

                    <Border Grid.Row="1"
                            Margin="0,18,0,0"
                            Background="{DynamicResource PanelBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12"
                            Padding="10">
                        <Grid>
                            <TextBlock x:Name="NoResultTextBlock"
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       Text="No lookup run yet."
                                       Margin="8,8,8,0"
                                       VerticalAlignment="Top"/>

                            <ListBox x:Name="ResultListBox"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                     ScrollViewer.CanContentScroll="False"
                                     SelectionChanged="ResultListBox_SelectionChanged">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="BorderThickness" Value="0"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type local:InternetLookupOption}">
                                        <Border x:Name="Card"
                                                Background="{DynamicResource CardBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="10"
                                                Padding="12">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBlock Grid.Column="0"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"
                                                               TextWrapping="Wrap"
                                                               Margin="0,0,10,0">
                                                        <Run Text="{Binding Title}"/>
                                                    </TextBlock>

                                                    <StackPanel Grid.Column="1"
                                                                Orientation="Horizontal"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top">
                                                        <Border Background="{DynamicResource StatusBadgeBackgroundBrush}"
                                                                BorderBrush="{DynamicResource AccentBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="8,3"
                                                                Margin="0,0,8,0">
                                                            <TextBlock Text="{Binding VerificationStatus}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                                                        </Border>
                                                        <Border Background="{DynamicResource StatusBadgeBackgroundBrush}"
                                                                BorderBrush="{DynamicResource AccentBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="8"
                                                                Padding="8,3">
                                                            <TextBlock Text="{Binding ConfidenceCaption}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource AccentBrush}"/>
                                                        </Border>
                                                    </StackPanel>
                                                </Grid>

                                                <TextBlock Text="{Binding Summary}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap"/>

                                                <StackPanel Margin="0,8,0,0">
                                                    <TextBlock TextWrapping="Wrap">
                                                        <Run Text="Source: "/><Run Text="{Binding SourceCaption}"/><Run Text=" · "/>
                                                        <Hyperlink NavigateUri="{Binding SourceUrl}" RequestNavigate="SourceLink_RequestNavigate">
                                                            <Run Text="{Binding SourceHostLabel}"/>
                                                        </Hyperlink>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding SourceDisplayUrl}"
                                                               Margin="0,4,0,0"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               FontSize="11"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <TextBlock Text="{Binding MatchSummary}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           TextWrapping="Wrap"/>

                                                <TextBlock Text="{Binding EvidenceLine}"
                                                           Margin="0,8,0,0"
                                                           Foreground="{DynamicResource MutedForegroundBrush}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=IsSelected}" Value="True">
                                                <Setter TargetName="Card" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter TargetName="Card" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource PanelCardBorderStyle}" Padding="14">
            <DockPanel>
                <TextBlock DockPanel.Dock="Left"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedForegroundBrush}"
                           Text="Apply writes the selected lookup result into the current config fields."/>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="ApplyButton" Content="Apply" Width="110" Height="34" Margin="0,0,8,0" Click="Apply_Click" IsEnabled="False"/>
                    <Button Content="Cancel" Width="110" Height="34" Click="Cancel_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
