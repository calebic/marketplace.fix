                                      Style="{StaticResource PresetComboBoxStyle}"
                                      SelectionChanged="InsuranceClassComboBox_SelectionChanged">
                                <ComboBoxItem Content="dailyDriver" IsSelected="True"/>
                                <ComboBoxItem Content="commercial"/>
                                <ComboBoxItem Content="prestige"/>
                            </ComboBox>

                            <TextBlock x:Name="PopulationPresetLabel" Grid.Row="11" Text="Preset" Style="{StaticResource FormFieldLabelStyle}"/>
