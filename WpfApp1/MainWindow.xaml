                                   x:Name="AutoValueUpDown"
                                   Margin="8,0,0,0"
                                   Minimum="0"
                                   Interval="100"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,0">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox x:Name="AutoPopulationCheckBox"
                          VerticalAlignment="Center"
                          Content="Population"/>
                                                            <mah:NumericUpDown Grid.Column="1"
                                   x:Name="AutoPopulationUpDown"
                                   Margin="8,0,0,0"
                                   Minimum="0"
                                   Maximum="1000000"
                                   Interval="10"/>
                                                        </Grid>
                                                    </StackPanel>
                                                </ScrollViewer>

                                            <StackPanel Grid.Row="2"
                                                        Orientation="Horizontal"
                                                        HorizontalAlignment="Right">
                                                <Button Content="Save"
                                                        Click="AutoFillSettingsSave_Click"/>
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Popup>

                        <Border x:Name="UnsavedBadge"
                                Background="{DynamicResource StatusBadgeBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="10,4"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Unsaved changes" Foreground="{DynamicResource AppForegroundBrush}" FontSize="11" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Border>

                        <Grid Margin="0,0,0,2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="108"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock x:Name="BrandLabel" Grid.Row="0" Text="Brand" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Grid.Row="0" Grid.Column="1" x:Name="BrandTextBox" Margin="10,2" TextChanged="FieldTextChanged"/>

                            <TextBlock x:Name="CountryLabel" Grid.Row="1" Text="Country" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Grid.Row="1" Grid.Column="1" x:Name="CountryTextBox" Margin="10,2" TextChanged="FieldTextChanged"/>

                            <TextBlock x:Name="TypeLabel" Grid.Row="2" Text="Type" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Grid.Row="2" Grid.Column="1" x:Name="TypeTextBox" Margin="10,2" TextChanged="FieldTextChanged"/>

                            <TextBlock x:Name="BodyStyleLabel" Grid.Row="3" Text="Body Style" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Grid.Row="3" Grid.Column="1" x:Name="BodyStyleTextBox" Margin="10,2" TextChanged="FieldTextChanged"/>

                            <TextBlock x:Name="ConfigTypeLabel" Grid.Row="4" Text="Config Type" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Grid.Row="4" Grid.Column="1" x:Name="ConfigTypeTextBox" Margin="10,2" TextChanged="FieldTextChanged"/>

                            <TextBlock x:Name="ConfigurationLabel" Grid.Row="5" Text="Configuration" Style="{StaticResource FormFieldLabelStyle}"/>
                            <TextBox Grid.Row="5" Grid.Column="1" x:Name="ConfigurationTextBox" Margin="10,2" TextChanged="FieldTextChanged"/>

                            <TextBlock x:Name="YearMinLabel" Grid.Row="6" Text="Year Min" Style="{StaticResource FormFieldLabelStyle}"/>
                            <mah:NumericUpDown Grid.Row="6" Grid.Column="1" x:Name="YearMinUpDown"
                                               Margin="10,2"
                                               Minimum="1900" Maximum="2200" Interval="1"
                                               ValueChanged="NumericFieldChanged"/>

                            <TextBlock x:Name="YearMaxLabel" Grid.Row="7" Text="Year Max" Style="{StaticResource FormFieldLabelStyle}"/>
                            <mah:NumericUpDown Grid.Row="7" Grid.Column="1" x:Name="YearMaxUpDown"
                                               Margin="10,2"
                                               Minimum="1900" Maximum="2200" Interval="1"
                                               ValueChanged="NumericFieldChanged"/>

                            <TextBlock x:Name="ValueLabel" Grid.Row="8" Text="Value" Style="{StaticResource FormFieldLabelStyle}"/>
                            <mah:NumericUpDown Grid.Row="8" Grid.Column="1" x:Name="ValueUpDown"
                                               Margin="10,2"
                                               Minimum="0" Interval="100"
                                               ValueChanged="NumericFieldChanged"/>

                            <TextBlock x:Name="PopulationLabel" Grid.Row="9" Text="Population" Style="{StaticResource FormFieldLabelStyle}"/>
                            <mah:NumericUpDown Grid.Row="9" Grid.Column="1" x:Name="PopulationUpDown"
                                               Margin="10,2"
                                               Minimum="0" Maximum="1000000" Interval="10"
                                               ValueChanged="NumericFieldChanged"/>

                            <TextBlock x:Name="InsuranceClassLabel" Grid.Row="10" Text="Insurance Class" Style="{StaticResource FormFieldLabelStyle}"/>
