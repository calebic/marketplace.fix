            <Border Panel.ZIndex="5" x:Name="ReviewQueuePage" Grid.Row="2" Margin="14,14,14,12" Grid.Column="2" Grid.ColumnSpan="3" Padding="18" Style="{StaticResource PanelCardBorderStyle}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Flagged Configs" FontSize="20" FontWeight="SemiBold"/><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="Inspect individual configs that were marked missing, suspicious, or otherwise in need of review before you edit them manually." TextWrapping="Wrap"/></StackPanel>
                    <Border Grid.Row="1" Margin="0,18,0,0" Style="{StaticResource PanelCardBorderStyle}" Padding="14"><TextBlock x:Name="ReviewQueueSummaryTextBlock" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap" Text="Flagged configs show up here with their review reason so you can decide what to correct next."/></Border>
                    <DataGrid x:Name="FlaggedConfigsGrid" Grid.Row="2" Margin="0,14,0,0" ItemsSource="{Binding FlaggedConfigs}" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" ColumnWidth="*" RowHeight="32" SelectionMode="Single" SelectionUnit="FullRow" SelectionChanged="FlaggedConfigsGrid_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Vehicle" Binding="{Binding VehicleName}" Width="2.3*"/>
                            <DataGridTextColumn Header="Mod" Binding="{Binding ModName}" Width="1.6*"/>
                            <DataGridTextColumn Header="Review reason" Binding="{Binding ReviewReason}" Width="2.45*"/>
                            <DataGridTextColumn Header="Confidence" Binding="{Binding ConfidenceTier}" Width="0.9*"/>
                            <DataGridTextColumn Header="Missing" Binding="{Binding HasMissingText}" Width="0.7*"/>
                            <DataGridTextColumn Header="Suspicious" Binding="{Binding IsSuspiciousText}" Width="0.8*"/>
