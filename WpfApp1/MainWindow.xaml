                                    <WrapPanel>
                                        <Border x:Name="DecisionStatusBadge"
                                                Background="{DynamicResource StatusBadgeBackgroundBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Padding="8,3"
                                                Margin="0,0,8,8">
                                            <TextBlock x:Name="DecisionStatusBadgeText"
                                                       Text="Idle"
                                                       FontSize="11"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AppForegroundBrush}"/>
                                        </Border>
                                        <TextBlock x:Name="DecisionSummaryTextBlock"
                                                   Width="290"
                                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                                   TextWrapping="Wrap"
                                                   Text="Select a config to see confidence, review pressure, and the latest autofill or lookup reasoning."/>
                                    </WrapPanel>
                                    <TextBlock x:Name="DecisionReviewTextBlock"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Text="Review reason: none yet."/>
                                    <TextBlock x:Name="DecisionIdentityEvidenceTextBlock"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Text="Identity evidence: none recorded yet."/>
                                    <TextBlock x:Name="DecisionValuationEvidenceTextBlock"
                                               Margin="0,8,0,0"
                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                               TextWrapping="Wrap"
                                               Text="Valuation evidence: none recorded yet."/>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>


            <Border Panel.ZIndex="5" x:Name="DashboardPage" Grid.Row="2" Margin="14,14,14,12" Grid.Column="2" Grid.ColumnSpan="3" Padding="18" Style="{StaticResource PanelCardBorderStyle}" Visibility="Collapsed">
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel>
                            <TextBlock Text="Dashboard" FontSize="20" FontWeight="SemiBold"/>
                            <TextBlock Margin="0,6,0,0" Text="Track scan health, review counts, recent activity, and jump directly into the pages that need attention." Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <UniformGrid Grid.Row="1" Margin="0,18,0,18" Columns="5">
                            <Border Style="{StaticResource AccentPanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Mods" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DashboardModsCountTextBlock" Text="0" FontSize="28" FontWeight="SemiBold"/></StackPanel></Border>
                            <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Configs" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock Text="{Binding Configs.Count}" FontSize="28" FontWeight="SemiBold"/></StackPanel></Border>
                            <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Needs review" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DashboardReviewCountTextBlock" Text="0" FontSize="28" FontWeight="SemiBold"/></StackPanel></Border>
                            <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Missing fields" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DashboardMissingCountTextBlock" Text="0" FontSize="28" FontWeight="SemiBold"/></StackPanel></Border>
                            <Border Style="{StaticResource PanelCardBorderStyle}" Padding="16,14"><StackPanel><TextBlock Text="Suspicious" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DashboardSuspiciousCountTextBlock" Text="0" FontSize="28" FontWeight="SemiBold"/></StackPanel></Border>
                        </UniformGrid>
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource PanelCardBorderStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Quick actions" FontSize="16" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,6,0,14" Foreground="{DynamicResource MutedForegroundBrush}" Text="Jump back into results, open the review queue, or open the mod library and review workflow." TextWrapping="Wrap"/>
                                    <WrapPanel>
                                        <Button Content="Open Configuration Editor" Padding="16,8" Margin="0,0,10,10" Click="OpenResultsPage_Click"/>
                                        <Button Content="Open Review Queue" Padding="16,8" Margin="0,0,10,10" Click="OpenReviewQueuePage_Click"/>
                                        <Button Content="Open Mod Library" Padding="16,8" Margin="0,0,10,10" Click="OpenRenamerPage_Click"/>
                                    </WrapPanel>
                                    <Border Margin="0,8,0,0" Style="{StaticResource PanelCardBorderStyle}" Padding="14">
                                        <StackPanel>
                                            <TextBlock Text="Install summary" FontWeight="SemiBold"/>
                                            <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap" x:Name="DashboardInstallSummaryTextBlock" Text="Scan a repo to show how many unique mods, brands, and flagged items were detected."/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>
                            <Grid Grid.Column="1" Margin="14,0,0,0">
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                                <Border Style="{StaticResource PanelCardBorderStyle}" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Top brands in repo" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Margin="0,8,0,10" Foreground="{DynamicResource MutedForegroundBrush}" Text="This breakdown updates after scans and autofill runs so you can see what the repo is mostly made of. Click a brand row to open a breakdown window showing the source zips and configs currently counted under it." TextWrapping="Wrap"/>
                                        <DataGrid x:Name="DashboardBrandStatsGrid" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" CanUserAddRows="False" ColumnWidth="*" RowHeight="30" MinHeight="170" MouseLeftButtonUp="DashboardBrandStatsGrid_MouseLeftButtonUp" Cursor="Hand">
                                            <DataGrid.Columns>
                                                <DataGridTextColumn Header="Brand" Binding="{Binding Label}" Width="*"/>
                                                <DataGridTextColumn Header="Configs" Binding="{Binding Count}" Width="0.7*"/>
                                            </DataGrid.Columns>
                                        </DataGrid>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Row="1" Margin="0,14,0,0" Style="{StaticResource PanelCardBorderStyle}" Padding="16">
                                    <StackPanel>
                                        <TextBlock Text="Recent activity" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock x:Name="DashboardRecentActivityTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap" Text="Scan a repo or run autofill to populate this dashboard with live status context."/>
                                        <Border Margin="0,14,0,0" Style="{StaticResource PanelCardBorderStyle}" Padding="14">
                                            <StackPanel>
                                                <TextBlock Text="Issue sources" FontWeight="SemiBold"/>
                                                <TextBlock x:Name="DashboardIssueSummaryTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap" Text="No issue sources recorded yet."/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Grid>
                    </Grid>
                </ScrollViewer>
