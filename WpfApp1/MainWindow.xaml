                    <Grid>
                        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
                        <StackPanel><TextBlock Text="Settings" FontSize="20" FontWeight="SemiBold"/><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="Customize the app shell, startup behavior, and a few core autofill defaults without leaving the workspace." TextWrapping="Wrap"/></StackPanel>
                        <Grid Grid.Row="1" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource PanelCardBorderStyle}" Padding="16" Margin="0,0,14,0">
                                <StackPanel>
                                    <TextBlock Text="Application" FontWeight="SemiBold"/>
                                    <Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Dark mode" VerticalAlignment="Center"/><mah:ToggleSwitch x:Name="SettingsThemeToggleSwitch" Grid.Column="1" Width="70" Height="30" HorizontalAlignment="Right" Toggled="SettingsThemeToggleSwitch_Toggled"/></Grid>
                                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Backup before save" VerticalAlignment="Center"/><mah:ToggleSwitch x:Name="SettingsBackupToggleSwitch" Grid.Column="1" Width="70" Height="30" HorizontalAlignment="Right" Toggled="SettingsBackupToggleSwitch_Toggled"/></Grid>
                                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Input into 'Vehicles'" VerticalAlignment="Center"/><mah:ToggleSwitch x:Name="SettingsVehiclesToggleSwitch" Grid.Column="1" Width="70" Height="30" HorizontalAlignment="Right" Toggled="SettingsVehiclesToggleSwitch_Toggled"/></Grid>
                                    <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions><TextBlock Text="Theme palette" VerticalAlignment="Center"/><ComboBox x:Name="SettingsAccentColorComboBox" Grid.Column="1" Width="160" HorizontalAlignment="Right" Margin="0" Style="{StaticResource PresetComboBoxStyle}" SelectionChanged="SettingsAccentColorComboBox_SelectionChanged"><ComboBoxItem Content="Blue" Tag="Blue"/><ComboBoxItem Content="Green" Tag="Green"/><ComboBoxItem Content="Purple" Tag="Purple"/><ComboBoxItem Content="Orange" Tag="Orange"/><ComboBoxItem Content="Red" Tag="Red"/></ComboBox></Grid>
                                    <TextBlock Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="Theme palettes now recolor the highlight accents and the app's blue-tinted chrome/card surfaces so the whole project can shift to a different color family." TextWrapping="Wrap"/>
                                    <WrapPanel Margin="0,10,0,0">
                                        <Border Width="18" Height="18" Margin="0,0,8,0" CornerRadius="9" Background="#6AB8FF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                        <Border Width="18" Height="18" Margin="0,0,8,0" CornerRadius="9" Background="#62DB8A" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                        <Border Width="18" Height="18" Margin="0,0,8,0" CornerRadius="9" Background="#B490FF" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                        <Border Width="18" Height="18" Margin="0,0,8,0" CornerRadius="9" Background="#FFB25B" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                        <Border Width="18" Height="18" Margin="0,0,8,0" CornerRadius="9" Background="#FF7676" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"/>
                                        <TextBlock VerticalAlignment="Center" Foreground="{DynamicResource MutedForegroundBrush}" Text="Quick preview of the available accent presets."/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource PanelCardBorderStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Startup &amp; workflow" FontWeight="SemiBold"/>
                                    <Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions><TextBlock Text="Default startup page" VerticalAlignment="Center"/><ComboBox x:Name="SettingsStartupPageComboBox" Grid.Column="1" Width="160" HorizontalAlignment="Right" Margin="0" Style="{StaticResource PresetComboBoxStyle}" SelectionChanged="SettingsStartupPageComboBox_SelectionChanged"><ComboBoxItem Content="Dashboard" Tag="Dashboard"/><ComboBoxItem Content="Configuration Editor" Tag="Results"/><ComboBoxItem Content="Review Queue" Tag="ReviewQueue"/><ComboBoxItem Content="Logs" Tag="Logs"/><ComboBoxItem Content="Data / JSON" Tag="Data"/><ComboBoxItem Content="Settings" Tag="Settings"/></ComboBox></Grid>
                                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Reopen last mods folder" VerticalAlignment="Center"/><mah:ToggleSwitch x:Name="SettingsReopenLastFolderToggleSwitch" Grid.Column="1" Width="70" Height="30" HorizontalAlignment="Right" Toggled="SettingsReopenLastFolderToggleSwitch_Toggled"/></Grid>
                                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Send weak matches to review" VerticalAlignment="Center"/><mah:ToggleSwitch x:Name="SettingsHoldWeakMatchesToggleSwitch" Grid.Column="1" Width="70" Height="30" HorizontalAlignment="Right" Toggled="SettingsHoldWeakMatchesToggleSwitch_Toggled"/></Grid>
                                    <Grid Margin="0,10,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="110"/></Grid.ColumnDefinitions><TextBlock Text="Open review queue after auto-fill" VerticalAlignment="Center"/><mah:ToggleSwitch x:Name="SettingsOpenReviewAfterAutoFillToggleSwitch" Grid.Column="1" Width="70" Height="30" HorizontalAlignment="Right" Toggled="SettingsOpenReviewAfterAutoFillToggleSwitch_Toggled"/></Grid>
                                    <Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="180"/></Grid.ColumnDefinitions><TextBlock Text="Lookup timeout (seconds)" VerticalAlignment="Center"/><mah:NumericUpDown x:Name="SettingsLookupTimeoutUpDown" Grid.Column="1" Width="120" HorizontalAlignment="Right" Minimum="3" Maximum="30" Interval="1" ValueChanged="SettingsLookupTimeoutUpDown_ValueChanged"/></Grid>
                                </StackPanel>
                            </Border>
                        </Grid>
                        <Grid Grid.Row="2" Margin="0,18,0,0">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="1.15*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Style="{StaticResource PanelCardBorderStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="Current workspace settings" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="SettingsCurrentFolderTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="SettingsReviewSummaryTextBlock" Margin="0,10,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                                    <TextBlock x:Name="SettingsDataSummaryTextBlock" Margin="0,10,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Grid.Column="1" Style="{StaticResource PanelCardBorderStyle}" Padding="16" Margin="14,0,0,0">
                                <StackPanel>
                                    <TextBlock Text="Auto-fill presets" FontWeight="SemiBold"/>
                                    <TextBlock Margin="0,8,0,14" Foreground="{DynamicResource MutedForegroundBrush}" Text="Detailed field-level defaults still live in the dedicated Auto-fill Settings popup. These new page settings control startup, review behavior, timeout, and appearance." TextWrapping="Wrap"/>
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="OpenAutoFillSettingsFromPageButton" Content="Open Auto-fill Settings" Width="180" Click="OpenAutoFillSettingsFromPage_Click"/>
                                        <Button x:Name="ResetSettingsDefaultsButton" Content="Reset page defaults" Width="160" Margin="10,0,0,0" Click="ResetSettingsDefaultsButton_Click"/>
                                    </StackPanel>
                                    <TextBlock Margin="0,10,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="Reset page defaults puts startup, accent, timeout, and review-flow preferences back to the project defaults." TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>

        <Border Grid.Row="3" Margin="14,0,14,14" Padding="14,8" Background="{DynamicResource CardBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Status &amp; activity" FontWeight="SemiBold" FontSize="13"/>
                    <ProgressBar x:Name="AutoFillProgressBar" Height="12" Margin="0,10,0,0" Minimum="0" Maximum="100" Visibility="Collapsed" IsIndeterminate="False"/>
                    <TextBlock x:Name="StatusTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <TextBlock x:Name="StatusDetailTextBlock" Margin="0,4,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap" FontSize="11"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10,5" Margin="10,0,0,0">
                        <TextBlock x:Name="FooterWorkspacePageTextBlock" Text="Page: Configuration Editor" FontWeight="SemiBold" FontSize="11"/>
                    </Border>
                    <Border Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="10" Padding="10,5" Margin="10,0,0,0">
                        <TextBlock x:Name="FooterRepoStateTextBlock" Text="Repo not loaded" FontWeight="SemiBold" FontSize="11"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Border x:Name="AutoFillOverlay"
                Grid.RowSpan="4"
                Panel.ZIndex="500"
                Background="#B3141722"
                Visibility="Collapsed">
            <Grid>
                <Border Width="560"
                        MaxWidth="560"
                        Padding="22"
                        CornerRadius="18"
                        Background="{DynamicResource CardBackgroundBrush}"
                        BorderBrush="{DynamicResource AccentBorderBrush}"
                        BorderThickness="1.2"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Effect="{DynamicResource CardShadowEffect}">
                    <StackPanel>
                        <TextBlock Text="Operation in progress"
                                   FontSize="20"
                                   FontWeight="SemiBold"/>
                        <TextBlock Margin="0,8,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   TextWrapping="Wrap"
                                   Text="Autofill is running. Please wait until it finishes, or cancel the run."/>
                        <ProgressBar x:Name="AutoFillOverlayProgressBar"
                                     Height="16"
                                     Margin="0,18,0,0"
                                     Minimum="0"
                                     Maximum="100"
                                     IsIndeterminate="False"/>
                        <TextBlock x:Name="AutoFillOverlayStatusTextBlock"
                                   Margin="0,12,0,0"
                                   FontWeight="SemiBold"
                                   Text="Preparing auto-fill run..."/>
                        <TextBlock x:Name="AutoFillOverlayDetailTextBlock"
                                   Margin="0,6,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   TextWrapping="Wrap"
                                   Text="Please wait while configs are processed."/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button x:Name="AutoFillOverlayCancelButton"
                                    Content="Cancel run"
                                    MinWidth="116"
                                    Height="34"
                                    Click="CancelAutoFillAll_Click"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</mah:MetroWindow>


