            <Border Panel.ZIndex="5" x:Name="DataPage" Grid.Row="2" Margin="14,14,14,12" Grid.Column="2" Grid.ColumnSpan="3" Padding="18" Style="{StaticResource PanelCardBorderStyle}" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel><TextBlock Text="Data / JSON" FontSize="20" FontWeight="SemiBold"/><TextBlock Margin="0,6,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="The inference engine now leans on external datasets. This page is the home for validation, reload, and visibility into what is loaded." TextWrapping="Wrap"/></StackPanel>
                    <UniformGrid Grid.Row="1" Margin="0,18,0,0" Columns="4">
                        <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Makes" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DataMakesCountTextBlock" Text="0" FontSize="24" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Profiles" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DataProfilesCountTextBlock" Text="0" FontSize="24" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Pricing rules" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DataPricingRulesCountTextBlock" Text="0" FontSize="24" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border Style="{StaticResource PanelCardBorderStyle}" Padding="16,14"><StackPanel><TextBlock Text="Trim keywords" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="DataTrimKeywordsCountTextBlock" Text="0" FontSize="24" FontWeight="SemiBold"/></StackPanel></Border>
                    </UniformGrid>
                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.25*"/><ColumnDefinition Width="1*"/></Grid.ColumnDefinitions>
