                    <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                    <StackPanel>
                        <TextBlock Text="Mod Library" FontSize="20" FontWeight="SemiBold"/>
                        <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource MutedForegroundBrush}" Text="Browse the detected mods in the current workspace, see which ones are maps or vehicles, check review pressure by mod, and launch the review wizard only when a mod still needs help." TextWrapping="Wrap"/>
                    </StackPanel>
                    <UniformGrid Grid.Row="1" Margin="0,18,0,0" Columns="4">
                        <Border Style="{StaticResource AccentPanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Detected mods" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="RenamerDetectedModsCountTextBlock" Text="0" FontSize="26" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Vehicle mods" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="RenamerVehicleModsCountTextBlock" Text="0" FontSize="26" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border Style="{StaticResource PanelCardBorderStyle}" Margin="0,0,12,0" Padding="16,14"><StackPanel><TextBlock Text="Map mods" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="RenamerMapModsCountTextBlock" Text="0" FontSize="26" FontWeight="SemiBold"/></StackPanel></Border>
                        <Border Style="{StaticResource PanelCardBorderStyle}" Padding="16,14"><StackPanel><TextBlock Text="Review queue mods" Foreground="{DynamicResource MutedForegroundBrush}"/><TextBlock x:Name="RenamerQueuedCountTextBlock" Text="0" FontSize="26" FontWeight="SemiBold"/></StackPanel></Border>
                    </UniformGrid>
                    <Grid Grid.Row="2" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="1.45*"/><ColumnDefinition Width="0.95*"/></Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Style="{StaticResource PanelCardBorderStyle}" Padding="16">
