                                <TextBlock Text="Dataset location" FontWeight="SemiBold"/>
                                <TextBlock x:Name="DataFolderPathTextBlock" Margin="0,8,0,0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="Wrap"/>
                                <WrapPanel Margin="0,14,0,0">
