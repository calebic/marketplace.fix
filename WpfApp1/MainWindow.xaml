                        </Border>
                    </Grid>
                </Grid>
            </Border>

            <Border Panel.ZIndex="5" x:Name="SettingsPage" Grid.Row="2" Margin="14,14,14,12" Grid.Column="2" Grid.ColumnSpan="3" Padding="18" Style="{StaticResource PanelCardBorderStyle}" Visibility="Collapsed">
