                                   x:Name="AutoYearUpDown"
                                   Margin="8,0,0,0"
                                   Minimum="1900"
                                   Maximum="2200"
                                   Interval="1"/>
                                                        </Grid>

                                                        <Grid Margin="0,0,0,8">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <CheckBox x:Name="AutoValueCheckBox"
                          VerticalAlignment="Center"
                          Content="Value"/>
