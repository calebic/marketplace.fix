                                    MinWidth="220"
                                    Height="38"
                                    Margin="0,18,0,0"
                                    Padding="18,6"
                                    Click="SaveChanges_Click"
                                    IsEnabled="False"/>

                            <Border Grid.Row="13" Grid.Column="0" Grid.ColumnSpan="2"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource PanelCardBorderStyle}"
