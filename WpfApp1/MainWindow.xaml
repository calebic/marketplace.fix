<mah:MetroWindow x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="BeamNG Marketplace Fixer" Height="900" Width="1580" MinWidth="1280" MinHeight="780"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        FontFamily="Bahnschrift"
        WindowStyle="None"
        ResizeMode="CanResize"
        UseNoneWindowStyle="True"
        ShowTitleBar="False"
        ShowMinButton="False"
        ShowMaxRestoreButton="False"
        ShowCloseButton="False"
        BorderBrush="{DynamicResource ShellOutlineBrush}"
        BorderThickness="1"
        PreviewKeyDown="Window_PreviewKeyDown"
        Icon="pack://application:,,,/beamngvehiclemarketplaceicon%20(1).ico">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="34" ResizeBorderThickness="6" GlassFrameThickness="0"/>
    </shell:WindowChrome.WindowChrome>
    <Grid x:Name="RootGrid" Margin="0" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Canvas IsHitTestVisible="False" ClipToBounds="True" Panel.ZIndex="-1">
            <Ellipse Width="420" Height="420" Canvas.Left="-130" Canvas.Top="-120" Opacity="0.14">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#4D6AB8FF" Offset="0"/>
                        <GradientStop Color="#006AB8FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
            <Ellipse Width="520" Height="520" Canvas.Right="-180" Canvas.Top="140" Opacity="0.10">
                <Ellipse.Fill>
                    <RadialGradientBrush>
                        <GradientStop Color="#3358B0FF" Offset="0"/>
                        <GradientStop Color="#0058B0FF" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>
        </Canvas>

        <Border Grid.Row="0"
        Background="{DynamicResource TitleBarGradientBrush}"
        BorderBrush="{DynamicResource BorderBrush}"
        BorderThickness="0,0,0,1"
        Margin="0,0,0,0"
        >
            <Grid x:Name="TitleBar"
          Height="36"
          VerticalAlignment="Center"
          MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button x:Name="LeftNavToggleButton"
                Grid.Column="0"
                Width="34"
                Height="28"
                Margin="8,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource TitleBarButtonStyle}"
                Content="☰"
                FontSize="14"
                FontWeight="SemiBold"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                ToolTip="Collapse or expand navigation"
                Click="LeftNavToggleButton_Click">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Root" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Root" Property="Opacity" Value="0.65"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <Grid Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="22" Height="22" CornerRadius="6" Background="Transparent" BorderBrush="{DynamicResource AccentBorderBrush}" BorderThickness="1" VerticalAlignment="Center">
                        <Image Source="pack://application:,,,/beamngvehiclemarketplaceicon%20(1).ico" Width="14" Height="14" Opacity="0.92" Stretch="Uniform" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="10,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="BeamNG Marketplace Fixer Enhanced" Foreground="{DynamicResource AppForegroundBrush}" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="Original Marketplace Fixer by Calebic | Discord: @ic.ey     Enhanced Marketplace version by T-ShadowOfficial | Discord:xxtshadowofficialxx"
                                   Margin="10,1,0,0"
                                   Foreground="{DynamicResource MutedForegroundBrush}"
                                   FontStyle="Italic"
                                   FontSize="11"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>

                <Button Grid.Column="2"
                Content="&#x2014;"
                Margin="0,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource TitleBarButtonStyle}"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="Minimize_Click"/>

                <Button x:Name="MaxRestoreButton" Grid.Column="3"
                Margin="4,0,0,0"
                VerticalAlignment="Center"
                Style="{StaticResource TitleBarButtonStyle}"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="MaximizeRestore_Click"
                ToolTip="Maximize or restore window">
                    <TextBlock x:Name="MaxRestoreGlyph"
                               Text="&#x25A1;"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Button>

                <Button Grid.Column="4"
                Content="&#x2715;"
                Margin="4,0,8,0"
                VerticalAlignment="Center"
                Style="{StaticResource TitleBarDangerButtonStyle}"
                shell:WindowChrome.IsHitTestVisibleInChrome="True"
                Click="Close_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="1" Padding="16,12" Style="{StaticResource PanelCardBorderStyle}" Margin="14,10,14,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Vertical">
                    <TextBlock Text="Mods Location" FontSize="15" FontWeight="SemiBold"/>
                    <TextBlock Margin="0,4,0,0" Text="Choose your mods folder, scan it, then review or autofill results from the workspace below." Foreground="{DynamicResource MutedForegroundBrush}"/>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="ModsPathTextBox" Grid.Column="0" Margin="0" MinHeight="36" VerticalContentAlignment="Center" mah:TextBoxHelper.ClearTextButton="True"/>
                        <Button x:Name="BrowseButton" Grid.Column="1" Content="Browse" MinWidth="110" Margin="12,0,0,0" Click="BrowseMods_Click"/>
                        <Button x:Name="ScanButton" Grid.Column="2" Content="Scan" MinWidth="94" Margin="10,0,0,0" Click="ScanMods_Click"/>
                        <Button x:Name="AutoFillAllButton" Grid.Column="3" Content="Auto Fill All" MinWidth="126" Margin="10,0,0,0" Click="AutoFillAll_Click"/>
                                            </Grid>
                </StackPanel>


            </Grid>
        </Border>

        <Grid x:Name="MainWorkspaceGrid" Grid.Row="2" Margin="14,14,14,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftNavColumn" Width="160"/>
                <ColumnDefinition x:Name="LeftNavSpacerColumn" Width="8"/>
                <ColumnDefinition Width="3.15*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.28*" MinWidth="390"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="NavigationRailBorder" Grid.Column="0" Padding="14" Style="{StaticResource PanelCardBorderStyle}">
                <StackPanel>
                    <Button x:Name="DashboardNavButton" Style="{StaticResource NavigationButtonStyle}" Margin="0,0,0,8" Click="WorkspaceNavButton_Click" Tag="Dashboard">Dashboard</Button>
                    <Button x:Name="ResultsNavButton" Style="{StaticResource NavigationButtonActiveStyle}" Margin="0,0,0,8" Click="WorkspaceNavButton_Click" Tag="Results">Configuration Editor</Button>
                    <Button x:Name="ReviewQueueNavButton" Style="{StaticResource NavigationButtonStyle}" Margin="0,0,0,8" Click="WorkspaceNavButton_Click" Tag="ReviewQueue">Flagged Configs</Button>
                    <Button x:Name="RenamerNavButton" Style="{StaticResource NavigationButtonStyle}" Margin="0,0,0,8" Click="WorkspaceNavButton_Click" Tag="Renamer">Mod Library</Button>
                    <Button x:Name="LicensePlatesNavButton" Style="{StaticResource NavigationButtonStyle}" Margin="0,0,0,8" Click="WorkspaceNavButton_Click" Tag="LicensePlates">License Plates</Button>
                    <Button x:Name="LogsNavButton" Style="{StaticResource NavigationButtonStyle}" Margin="0,0,0,8" Click="WorkspaceNavButton_Click" Tag="Logs">Logs</Button>
                    <Button x:Name="DataNavButton" Style="{StaticResource NavigationButtonStyle}" Margin="0,0,0,8" Click="WorkspaceNavButton_Click" Tag="Data">Data / JSON</Button>
                    <Button x:Name="SettingsNavButton" Style="{StaticResource NavigationButtonStyle}" Click="WorkspaceNavButton_Click" Tag="Settings">Settings</Button>
                </StackPanel>
            </Border>

            <GridSplitter x:Name="InspectorSplitter" Grid.Column="3" Width="10" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Background="Transparent"/>

            <Border x:Name="ResultsWorkspaceBorder" Grid.Column="2" Padding="12" Style="{StaticResource PanelCardBorderStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Text="Configuration Editor" FontSize="18" Style="{StaticResource SectionTitleTextBlockStyle}" Margin="2,0,0,10"/>
                    <Grid Grid.Row="1" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="SearchTextBox" Grid.Column="0" Margin="0" Height="30"
                                 VerticalContentAlignment="Center" TextChanged="SearchTextBox_TextChanged"
                                 mah:TextBoxHelper.ClearTextButton="True"
                                 ToolTip="Search mod, model, config, or name"/>
                        <CheckBox x:Name="MissingOnlyCheckBox" Grid.Column="1" Margin="10,0,0,0"
                                  VerticalAlignment="Center" Content="Missing only"
                                  Checked="FilterControl_Changed" Unchecked="FilterControl_Changed"/>
                        <CheckBox x:Name="GroupByModCheckBox" Grid.Column="2" Margin="12,0,0,0"
                                  VerticalAlignment="Center" Content="Group by mod" IsChecked="True"
                                  Checked="GroupByModCheckBox_Changed" Unchecked="GroupByModCheckBox_Changed"/>
                        <CheckBox x:Name="MissingFirstCheckBox" Grid.Column="3" Margin="12,0,0,0"
                                  VerticalAlignment="Center" Content="Missing first"
                                  Checked="SortControl_Changed" Unchecked="SortControl_Changed"/>
                    </Grid>
                    <Grid Grid.Row="2">
                        <Border x:Name="EmptyStateContainer"
                                Background="{DynamicResource SurfaceBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12,8"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock x:Name="EmptyStateTextBlock" Text="No configs match your filters."
                                       Foreground="{DynamicResource MutedForegroundBrush}"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       TextAlignment="Center"/>
                        </Border>
                        <DataGrid x:Name="ConfigsGrid"
          ItemsSource="{Binding Configs}"
          AutoGenerateColumns="False"
          IsReadOnly="True"
          SelectionMode="Single"
          SelectionUnit="FullRow"
          FocusVisualStyle="{x:Null}"
          SelectionChanged="ConfigsGrid_SelectionChanged"
          HeadersVisibility="Column"
          ColumnWidth="*"
          VirtualizingPanel.IsVirtualizing="True"
          VirtualizingPanel.VirtualizationMode="Recycling"
          VirtualizingPanel.IsVirtualizingWhenGrouping="True"
          ScrollViewer.CanContentScroll="True"
          EnableRowVirtualization="True"
          EnableColumnVirtualization="False"
          GridLinesVisibility="None"
          Foreground="{DynamicResource AppForegroundBrush}"
          Background="{DynamicResource CardBackgroundBrush}"
          BorderBrush="{DynamicResource BorderBrush}"
          BorderThickness="1"
          RowHeight="32">

                            <DataGrid.Resources>
                                <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="Transparent"/>
                                <SolidColorBrush x:Key="{x:Static SystemColors.InactiveSelectionHighlightBrushKey}" Color="Transparent"/>
                            </DataGrid.Resources>

                            <DataGrid.ColumnHeaderStyle>
                                <Style TargetType="DataGridColumnHeader">
                                    <Setter Property="Background" Value="{DynamicResource SurfaceBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                                    <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                    <Setter Property="Padding" Value="10,6"/>
                                    <Setter Property="FontWeight" Value="SemiBold"/>
                                    <Setter Property="Height" Value="30"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                </Style>
                            </DataGrid.ColumnHeaderStyle>

                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AppForegroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,0,2"/>
                                    <Setter Property="SnapsToDevicePixels" Value="True"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="DataGridRow">
                                                <Border x:Name="RowBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="6"
                                Padding="0">
                                                    <SelectiveScrollingGrid>
                                                        <SelectiveScrollingGrid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </SelectiveScrollingGrid.ColumnDefinitions>
                                                        <SelectiveScrollingGrid.RowDefinitions>
                                                            <RowDefinition Height="*"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </SelectiveScrollingGrid.RowDefinitions>

                                                        <DataGridCellsPresenter Grid.Column="1"/>
                                                        <DataGridDetailsPresenter Grid.Column="1"
                                                          Grid.Row="1"
                                                          Visibility="{TemplateBinding DetailsVisibility}"/>
                                                    </SelectiveScrollingGrid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource HoverBrush}"/>
                                                    </Trigger>

                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter TargetName="RowBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        <Setter TargetName="RowBorder" Property="BorderThickness" Value="1"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                                                    </Trigger>

                                                    <MultiTrigger>
                                                        <MultiTrigger.Conditions>
                                                            <Condition Property="IsSelected" Value="True"/>
                                                            <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                                        </MultiTrigger.Conditions>
                                                        <Setter TargetName="RowBorder" Property="Background" Value="{DynamicResource SelectionBrush}"/>
                                                        <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                                                    </MultiTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </DataGrid.RowStyle>

                            <DataGrid.CellStyle>
                                <Style TargetType="DataGridCell">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="BorderBrush" Value="Transparent"/>
                                    <Setter Property="BorderThickness" Value="0"/>
                                    <Setter Property="Padding" Value="10,4"/>
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                    <Setter Property="VerticalContentAlignment" Value="Center"/>

                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="Transparent"/>
                                            <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                                            <Setter Property="BorderBrush" Value="Transparent"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.CellStyle>

                            <DataGrid.GroupStyle>
                                <GroupStyle>
                                    <GroupStyle.ContainerStyle>
                                        <Style TargetType="{x:Type GroupItem}">
                                            <Setter Property="Margin" Value="0,0,0,8"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="{x:Type GroupItem}">
                                                        <Border Background="Transparent"
                                        BorderBrush="Transparent"
                                        BorderThickness="0"
                                        Padding="0">
                                                            <Expander IsExpanded="False"
                                              Background="Transparent"
                                              BorderBrush="Transparent"
                                              BorderThickness="0"
                                              Padding="0">
                                                                <Expander.Template>
                                                                    <ControlTemplate TargetType="{x:Type Expander}">
                                                                        <StackPanel>
                                                                            <ToggleButton x:Name="GroupHeaderToggle"
                                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                                  Background="Transparent"
                                                                  BorderBrush="Transparent"
                                                                  BorderThickness="0"
                                                                  Padding="0"
                                                                  Margin="0,0,0,4"
                                                                  HorizontalAlignment="Stretch"
                                                                  HorizontalContentAlignment="Stretch"
                                                                  FocusVisualStyle="{x:Null}">
                                                                                <ToggleButton.Template>
                                                                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                                                        <Border x:Name="GroupHeaderBackground"
                                                                        Background="{DynamicResource SurfaceBrush}"
                                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                                        BorderThickness="1"
                                                                        CornerRadius="8"
                                                                        Height="30"
                                                                        Padding="10,0"
                                                                        SnapsToDevicePixels="True">
                                                                                            <ContentPresenter HorizontalAlignment="Stretch"
                                                                                      VerticalAlignment="Center"/>
                                                                                        </Border>
                                                                                        <ControlTemplate.Triggers>
                                                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                                                <Setter TargetName="GroupHeaderBackground"
                                                                                Property="Background"
                                                                                Value="{DynamicResource HoverBrush}"/>
                                                                                            </Trigger>
                                                                                            <Trigger Property="IsChecked" Value="True">
                                                                                                <Setter TargetName="GroupHeaderBackground"
                                                                                Property="Background"
                                                                                Value="{DynamicResource SelectionBrush}"/>
                                                                                                <Setter TargetName="GroupHeaderBackground"
                                                                                Property="BorderBrush"
                                                                                Value="{DynamicResource SelectionBrush}"/>
                                                                                            </Trigger>
                                                                                        </ControlTemplate.Triggers>
                                                                                    </ControlTemplate>
                                                                                </ToggleButton.Template>
                                                                                <ContentPresenter ContentSource="Header"/>
                                                                            </ToggleButton>

                                                                            <ContentPresenter x:Name="ExpandSite"
                                                                      ContentSource="Content"
                                                                      Visibility="Collapsed"/>
                                                                        </StackPanel>

                                                                        <ControlTemplate.Triggers>
                                                                            <Trigger Property="IsExpanded" Value="True">
                                                                                <Setter TargetName="ExpandSite"
                                                                Property="Visibility"
                                                                Value="Visible"/>
                                                                            </Trigger>
                                                                        </ControlTemplate.Triggers>
                                                                    </ControlTemplate>
                                                                </Expander.Template>

                                                                <Expander.Header>
                                                                    <Border Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="0"
                                                    CornerRadius="8"
                                                    Padding="0">
                                                                        <DockPanel>
                                                                            <TextBlock Text="{Binding Name}"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AppForegroundBrush}"/>
                                                                            <TextBlock Text="{Binding ItemCount, StringFormat=  ({0} configs)}"
                                                               Foreground="{DynamicResource MutedForegroundBrush}"
                                                               Margin="8,0,0,0"/>
                                                                        </DockPanel>
                                                                    </Border>
                                                                </Expander.Header>

                                                                <ItemsPresenter Margin="0,0,0,2"/>
                                                            </Expander>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </GroupStyle.ContainerStyle>
                                </GroupStyle>
                            </DataGrid.GroupStyle>

                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Name" Width="4.6*" MinWidth="240">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="Padding" Value="46,8,10,4"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <Grid VerticalAlignment="Center">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="StatusBadge"
        Grid.Column="0"
        Background="#1E22C55E"
        BorderBrush="#5522C55E"
        BorderThickness="1"
        CornerRadius="9"
        Padding="8,2"
        Margin="8,0,10,0"
        VerticalAlignment="Center">
                                                    <TextBlock x:Name="StatusText"
               Text="✔"
               Foreground="#166534"
               FontSize="10"
               FontWeight="SemiBold"
               VerticalAlignment="Center"/>
                                                </Border>

                                                <TextBlock Grid.Column="1"
                           Text="{Binding VehicleName}"
                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <DataTemplate.Triggers>
                                                <DataTrigger Binding="{Binding HasMissing}" Value="True">
                                                    <Setter TargetName="StatusText" Property="Text" Value="✖"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="Red"/>
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#14FF3B30"/>
                                                    <Setter TargetName="StatusBadge" Property="BorderBrush" Value="#30FF3B30"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding IsSuspicious}" Value="True">
                                                    <Setter TargetName="StatusText" Property="Text" Value="!"/>
                                                    <Setter TargetName="StatusText" Property="Foreground" Value="#C2410C"/>
                                                    <Setter TargetName="StatusBadge" Property="Background" Value="#14F59E0B"/>
                                                    <Setter TargetName="StatusBadge" Property="BorderBrush" Value="#30F59E0B"/>
                                                </DataTrigger>
                                            </DataTemplate.Triggers>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>

                                <DataGridTextColumn Header="Autofill" Binding="{Binding LastAutoFillStatus}" Width="1.4*" MinWidth="120"/>

                                <DataGridTextColumn Header="Method" Binding="{Binding LastAutoFillSource}" Width="1.5*" MinWidth="140"/>

                                <DataGridTextColumn Header="Review" Binding="{Binding ReviewReason}" Width="2.2*" MinWidth="180"/>

                                <DataGridTemplateColumn Width="2*" MinWidth="160">
                                    <DataGridTemplateColumn.HeaderStyle>
                                        <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                            <Setter Property="Padding" Value="54,6,10,6"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Left"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                        </Style>
                                    </DataGridTemplateColumn.HeaderStyle>

                                    <DataGridTemplateColumn.Header>
                                        <TextBlock Text="Config"/>
                                    </DataGridTemplateColumn.Header>

                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding ConfigKey}"
                       VerticalAlignment="Center"
                       Margin="0,1,0,0"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </Border>

            <Border x:Name="InspectorBorder" Grid.Column="4" Padding="16" Style="{StaticResource PanelCardBorderStyle}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="Configuration Editor" FontSize="16" Style="{StaticResource SectionTitleTextBlockStyle}"/>
                        <TextBlock x:Name="ConfigPathText" Visibility="Collapsed" Margin="0" Foreground="{DynamicResource MutedForegroundBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"/>

                        <TextBlock x:Name="ConfigSummaryText" Visibility="Collapsed" Foreground="{DynamicResource AppForegroundBrush}" FontWeight="SemiBold" Margin="0"/>
                        <TextBlock x:Name="SelectedModInfoTextBlock" Visibility="Collapsed" Foreground="{DynamicResource MutedForegroundBrush}" Margin="0" TextWrapping="Wrap"/>

                        <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="16" Padding="12" Margin="0,4,0,12" HorizontalAlignment="Stretch">
                            <StackPanel>
                                <Viewbox Stretch="Uniform" StretchDirection="DownOnly" HorizontalAlignment="Stretch">
