<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#09101D" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#15233A" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#101A2C" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#0D1626" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#0C1524" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#F4F8FF" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#F5F9FF" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#A8BDD8" />
    <SolidColorBrush x:Key="FormLabelBrush" Color="#C2D4EA" />
    <SolidColorBrush x:Key="BorderBrush" Color="#29415F" />
    <SolidColorBrush x:Key="AccentBrush" Color="#6AB8FF" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#F5F9FF" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#62DB8A" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FFB25B" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#FF7676" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#213A59" />
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#F5F9FF" />
    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#0E1728" />
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#1A2940" />
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#422C38" />
    <SolidColorBrush x:Key="HoverBrush" Color="#1B2E47" />
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#0D1728" />
    <SolidColorBrush x:Key="StatusBadgeBackgroundBrush" Color="#1E2F49" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#16253C" />
    <SolidColorBrush x:Key="CardGlowBrush" Color="#18385C" />
    <SolidColorBrush x:Key="ShellOutlineBrush" Color="#33547A" />

    <LinearGradientBrush x:Key="AppChromeGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#0C1525" Offset="0"/>
        <GradientStop Color="#0A1322" Offset="0.5"/>
        <GradientStop Color="#0D1A2B" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="TitleBarGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#111C30" Offset="0"/>
        <GradientStop Color="#0C1626" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="CardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#132238" Offset="0"/>
        <GradientStop Color="#0F1B2E" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentCardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#173457" Offset="0"/>
        <GradientStop Color="#122744" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
