<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="AppBackgroundBrush" Color="#E7EEF8" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#D6E2F3" />
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FCFEFF" />
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#F0F6FF" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="InputForegroundBrush" Color="#0F2845" />
    <SolidColorBrush x:Key="AppForegroundBrush" Color="#0B223D" />
    <SolidColorBrush x:Key="MutedForegroundBrush" Color="#3F5A7D" />
    <SolidColorBrush x:Key="FormLabelBrush" Color="#355273" />
    <SolidColorBrush x:Key="BorderBrush" Color="#97AEC9" />
    <SolidColorBrush x:Key="AccentBrush" Color="#1F7DD6" />
    <SolidColorBrush x:Key="AccentForegroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#1D7A3C" />
    <SolidColorBrush x:Key="WarningBrush" Color="#8A5A00" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#B42318" />
    <SolidColorBrush x:Key="SelectionBrush" Color="#C9DBF3" />
    <SolidColorBrush x:Key="SelectionForegroundBrush" Color="#0B223D" />

    <SolidColorBrush x:Key="TitleBarBackgroundBrush" Color="#D3DEEF" />
    <SolidColorBrush x:Key="ButtonBackgroundBrush" Color="#DFE8F6" />
    <SolidColorBrush x:Key="DangerButtonBackgroundBrush" Color="#F3E7EA" />
    <SolidColorBrush x:Key="HoverBrush" Color="#E0EBFA" />
    <SolidColorBrush x:Key="PopupBackgroundBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="StatusBadgeBackgroundBrush" Color="#D4E2F6" />
    <SolidColorBrush x:Key="GridHeaderBackgroundBrush" Color="#CCDAEE" />
    <SolidColorBrush x:Key="CardGlowBrush" Color="#D6E2F3" />
    <SolidColorBrush x:Key="ShellOutlineBrush" Color="#97AEC9" />

    <LinearGradientBrush x:Key="TitleBarGradientBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#DCE6F4" Offset="0"/>
        <GradientStop Color="#EEF4FC" Offset="1"/>
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="AccentCardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#E7F1FC" Offset="0"/>
        <GradientStop Color="#F8FBFF" Offset="1"/>
    </LinearGradientBrush>
</ResourceDictionary>
